# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="DisasterLens API"
APP_VERSION="1.0.0"
DEBUG=True

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=disasterlens

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Source Ingestion ──────────────────────────────────────────────────────────
SOURCE_ENABLE_PROTHOM_ALO=True
SOURCE_ENABLE_DAILY_STAR=False

# ── Crawling / Scraping ───────────────────────────────────────────────────────
PROTHOM_ALO_ENVIRONMENT_URL=https://www.prothomalo.com/bangladesh/environment/
NEWS_MAX_ARTICLES_PER_RUN=20
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_USER_AGENT="DisasterLensBot/1.0 (+https://your-domain-or-contact)"

# ── AI Summarization ──────────────────────────────────────────────────────────
AI_SUMMARIZER_PROVIDER=gemini
AI_SUMMARIZER_FALLBACKS=mistral,qwen

# ── Bangladesh Geo Reference Sources ─────────────────────────────────────────
BANGLA_GEO_DIVISIONS_URL=https://raw.githubusercontent.com/m3h3d1ha2an/banglageoapi/main/src/json/divisions.json
BANGLA_GEO_DISTRICTS_URL=https://raw.githubusercontent.com/m3h3d1ha2an/banglageoapi/main/src/json/districts.json
BANGLA_GEO_UPAZILAS_URL=https://raw.githubusercontent.com/m3h3d1ha2an/banglageoapi/main/src/json/upazilas.json
BANGLA_GEO_UNIONS_URL=https://raw.githubusercontent.com/m3h3d1ha2an/banglageoapi/main/src/json/unions.json
