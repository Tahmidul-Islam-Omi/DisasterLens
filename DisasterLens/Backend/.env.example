# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="DisasterLens API"
APP_VERSION="1.0.0"
DEBUG=True

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=disasterlens

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
